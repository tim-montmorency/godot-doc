{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch HTTPS Static Server",
      "program": "${workspaceFolder}/scripts/serve-https.js",
      "cwd": "${workspaceFolder}",
      "env": {
        "PORT": "8443",
        "HOST": "0.0.0.0"
      },
      "preLaunchTask": "Generate Self-Signed Cert",
      "console": "integratedTerminal"
    }
  ]
}
